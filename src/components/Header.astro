---
const DISCORD  = import.meta.env.PUBLIC_DISCORD_INVITE_URL;
const ROBLOX_G = import.meta.env.PUBLIC_ROBLOX_GROUP_URL;

const NAV_LINKS = [
  { label: 'Accueil',      href: '/' },
  { label: 'Le Jeu',       href: '/jeu' },
  { label: 'Développement', href: '/developpement' },
  { label: 'Communauté',   href: '/communaute' },
  { label: 'Crédits',      href: '/credits' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<!-- Page Transition Overlay -->
<div id="page-transition"></div>

<!-- SCP HUD -->
<div id="scp-hud" aria-hidden="true"></div>

<!-- Scanlines CRT -->
<div class="scanlines-overlay" aria-hidden="true"></div>
<div class="crt-vignette"      aria-hidden="true"></div>

<!-- Navigation -->
<nav class="scp-nav" id="scp-nav" role="navigation" aria-label="Navigation principale">
  <div class="nav-inner">

    <!-- Brand -->
    <a href="/" class="nav-brand" aria-label="SCP RP Site-21 — Accueil">
      <img src="/logos/site21_logo.webp" alt="" aria-hidden="true" class="nav-logo-img" />
      <div class="nav-brand-text">
        SCP RP SITE-21
        <span>FONDATION SECRÈTE DE PROTECTION</span>
      </div>
    </a>

    <!-- Hamburger -->
    <button class="nav-hamburger" aria-label="Menu" aria-expanded="false" id="nav-hamburger">
      <span></span><span></span><span></span>
    </button>

    <!-- Links -->
    <div class="nav-links" id="nav-links">
      {NAV_LINKS.map(({ label, href }) => (
        <a href={href} class:list={[{ active: isActive(href) }]}>
          {label}
        </a>
      ))}
    </div>

    <!-- Social -->
    <div class="nav-social">
      <a href={DISCORD} target="_blank" rel="noopener noreferrer" aria-label="Discord" class="nav-social-link nav-social-discord">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.056a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
        <span>Discord</span>
      </a>
      <a href={ROBLOX_G} target="_blank" rel="noopener noreferrer" aria-label="Roblox" class="nav-social-link nav-social-roblox">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.889 0L0 20.09 20.099 24 24 3.91zM15.053 17.03l-8.08-1.931 1.931-8.08 8.08 1.931z"/></svg>
        <span>Roblox</span>
      </a>
    </div>
  </div>
</nav>

<script>
/* ── Navbar scroll shrink + glass ── */
(function () {
  const nav = document.getElementById('scp-nav') as HTMLElement | null;
  if (!nav) return;
  const navEl = nav as HTMLElement;
  function update() {
    const past = window.scrollY > 50;
    navEl.style.height = past ? '72px' : '88px';
    navEl.classList.toggle('scrolled', past);
  }
  window.addEventListener('scroll', update, { passive: true });
  update();
})();

/* ── Hamburger ── */
(function () {
  const nav = document.getElementById('scp-nav');
  const btn = document.getElementById('nav-hamburger');
  if (!nav || !btn) return;
  btn.addEventListener('click', () => {
    const open = nav.classList.toggle('nav-open');
    btn.setAttribute('aria-expanded', String(open));
  });
  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => nav.classList.remove('nav-open'));
  });
  document.addEventListener('click', (e) => {
    if (!nav.contains(e.target as Node)) nav.classList.remove('nav-open');
  });
})();

/* ── Page Transitions ── */
(function () {
  const overlay = document.getElementById('page-transition');
  if (!overlay) return;
  overlay.classList.remove('active');
  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[href]') as HTMLAnchorElement | null;
    if (!link) return;
    const href = link.getAttribute('href');
    if (!href || href.startsWith('#') || href.startsWith('http') ||
        href.startsWith('mailto') || href.startsWith('tel') || link.target === '_blank') return;
    e.preventDefault();
    overlay.classList.add('active');
    setTimeout(() => { window.location.href = href; }, 220);
  });
})();

/* ── HUD ── */
(function () {
  const hud = document.getElementById('scp-hud');
  if (!hud) return;
  const utcOffset = -new Date().getTimezoneOffset() / 60;
  const utcLabel = `UTC${utcOffset >= 0 ? '+' : ''}${utcOffset}`;
  hud.innerHTML = `
    <div class="hud-tr">
      <span id="hud-clock">--:--:--</span>
      <span>${utcLabel}</span>
    </div>
    <div class="hud-bl">
      <span>NIV. SÉCURITÉ: <span style="color:var(--red-primary)">ROUGE</span></span>
      <span>PROTOCOLE: ACTIF</span>
    </div>
    <div class="hud-br">
      <span>CONNEXION: <span style="color:var(--green-bright)">ACTIVE</span></span>
      <span>SIGNAL: ████████░░</span>
    </div>`;
  function tick() {
    const el = document.getElementById('hud-clock');
    if (!el) return;
    const n = new Date();
    el.textContent = [n.getHours(), n.getMinutes(), n.getSeconds()]
      .map(v => String(v).padStart(2, '0')).join(':');
  }
  tick();
  setInterval(tick, 1000);
})();

/* ── Glitch Effect ── */
(function () {
  const style = document.createElement('style');
  style.textContent = `
    .glitch-text { position:relative; }
    .glitch-text::before,.glitch-text::after { content:attr(data-text);position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none; }
    .glitch-text::before { color:var(--red-hot);mix-blend-mode:screen;clip-path:inset(30% 0 50% 0);animation-play-state:paused; }
    .glitch-text::after  { color:var(--orange-alert);mix-blend-mode:screen;clip-path:inset(60% 0 20% 0);animation-play-state:paused;animation-direction:reverse; }
    .glitch-text.glitching::before { animation:glitch-before 0.05s steps(1) infinite;animation-play-state:running;transform:translateX(var(--glitch-offset,0)); }
    .glitch-text.glitching::after  { animation:glitch-after  0.05s steps(1) infinite;animation-play-state:running;transform:translateX(calc(-1*var(--glitch-offset,0))); }
    @keyframes glitch-before { 0%{clip-path:inset(20% 0 60% 0);transform:translateX(-4px)} 20%{clip-path:inset(55% 0 10% 0);transform:translateX(3px)} 40%{clip-path:inset(35% 0 40% 0);transform:translateX(-2px)} 60%{clip-path:inset(70% 0 5% 0);transform:translateX(5px)} 80%{clip-path:inset(10% 0 75% 0);transform:translateX(-3px)} 100%{clip-path:inset(45% 0 30% 0);transform:translateX(2px)} }
    @keyframes glitch-after  { 0%{clip-path:inset(60% 0 20% 0);transform:translateX(4px)} 20%{clip-path:inset(10% 0 55% 0);transform:translateX(-5px)} 40%{clip-path:inset(80% 0 5% 0);transform:translateX(2px)} 60%{clip-path:inset(25% 0 50% 0);transform:translateX(-4px)} 80%{clip-path:inset(50% 0 30% 0);transform:translateX(3px)} 100%{clip-path:inset(5% 0 80% 0);transform:translateX(-2px)} }
  `;
  document.head.appendChild(style);

  function glitch(el: HTMLElement) {
    el.classList.add('glitching');
    const offsets = [-5,-3,2,4,-2,3,-4,5];
    let count = 0, max = 6 + Math.floor(Math.random()*6);
    const tick = setInterval(() => {
      el.style.setProperty('--glitch-offset', offsets[Math.floor(Math.random()*offsets.length)] + 'px');
      if (++count >= max) { clearInterval(tick); el.style.removeProperty('--glitch-offset'); el.classList.remove('glitching'); }
    }, 40);
  }
  function schedule(el: HTMLElement) {
    setTimeout(() => { glitch(el); schedule(el); }, 3000 + Math.random()*8000);
  }
  document.querySelectorAll<HTMLElement>('[data-glitch]').forEach(el => {
    if (!el.dataset.text) el.dataset.text = el.textContent ?? '';
    el.classList.add('glitch-text');
    schedule(el);
  });
})();

/* ── Redacted ── */
document.querySelectorAll<HTMLElement>('.redacted').forEach(el => {
  let revealed = false;
  el.addEventListener('mouseenter', () => { if (!revealed) el.style.animation = 'redacted-reveal 0.4s ease both'; });
  el.addEventListener('mouseleave', () => { if (!revealed) el.style.animation = ''; });
  el.addEventListener('click', () => {
    revealed = !revealed;
    el.style.background  = revealed ? 'transparent' : '';
    el.style.color       = revealed ? 'var(--red-hot)' : '';
    el.style.textShadow  = revealed ? '0 0 8px var(--red-primary)' : '';
    el.style.animation   = '';
  });
});

/* ── Ambient Flicker ── */
(function flicker() {
  document.body.style.animation = 'flicker 0.2s steps(1)';
  setTimeout(() => { document.body.style.animation = ''; }, 200);
  setTimeout(flicker, 15000 + Math.random()*25000);
})();

/* ── Scroll Reveal ── */
(function () {
  const els = document.querySelectorAll('.scroll-reveal');
  if (!els.length) return;
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        el.style.transitionDelay = ((parseInt(el.dataset.stagger||'0',10))*100)+'ms';
        el.classList.add('revealed');
        obs.unobserve(el);
      }
    });
  }, { threshold: 0.12 });
  els.forEach(el => obs.observe(el));
})();

/* ── Counter Animation ── */
(function () {
  function easeOut(t: number) { return t===1?1:1-Math.pow(2,-10*t); }
  function run(el: HTMLElement) {
    const target = parseInt(el.dataset.countTo||'0',10);
    const start = performance.now();
    const suffix = el.dataset.suffix||'';
    (function frame(now: number) {
      const p = Math.min((now-start)/2000,1);
      el.textContent = Math.round(easeOut(p)*target).toLocaleString('fr-FR')+suffix;
      if (p<1) requestAnimationFrame(frame);
    })(start);
  }
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { run(e.target as HTMLElement); obs.unobserve(e.target); } });
  }, { threshold: 0.5 });
  document.querySelectorAll<HTMLElement>('[data-count-to]').forEach(el => obs.observe(el));
})();

/* ── News Toggle ── */
document.querySelectorAll<HTMLElement>('.news-card').forEach(card => {
  const btn = card.querySelector<HTMLElement>('.news-expand-btn');
  if (!btn) return;
  card.addEventListener('click', () => {
    const expanded = card.classList.toggle('expanded');
    btn.textContent = expanded ? 'RÉDUIRE ▲' : 'LIRE LA SUITE ▼';
  });
});
</script>
