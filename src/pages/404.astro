---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page introuvable — Site 21 RP">
  <section style="min-height:calc(100vh - 64px);display:flex;align-items:center;justify-content:center;padding:2rem 1.5rem;text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 50%, rgba(204,0,0,0.07) 0%, transparent 70%);pointer-events:none;"></div>
    <div style="position:relative;z-index:1;">
      <span class="section-tag">// Erreur système</span>
      <h1 style="font-family:'Rajdhani',sans-serif;font-size:clamp(5rem,20vw,10rem);font-weight:700;color:#cc0000;letter-spacing:0.08em;line-height:1;margin:0.5rem 0;">
        404
      </h1>
      <p style="font-family:'Share Tech Mono',monospace;font-size:0.88rem;color:#777;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:2rem;">
        Document introuvable — Accès refusé
      </p>
      <a href="/" class="btn-secondary">← Retour à l'accueil</a>
    </div>
  </section>
</Layout>
