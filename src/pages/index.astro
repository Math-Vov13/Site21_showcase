---
import Layout from "../layouts/Layout.astro";
import LightPillar from "../components/LightPillar.jsx";
const DISCORD = import.meta.env.PUBLIC_DISCORD_INVITE_URL;
const ROBLOX_G = import.meta.env.PUBLIC_ROBLOX_GROUP_URL;
const ROBLOX_J = import.meta.env.PUBLIC_ROBLOX_GAME_URL;
const TRELLO = import.meta.env.PUBLIC_TRELLO_URL;
---

<Layout
    title="Site 21 RP — Roleplay SCP sur Roblox"
    description="Rejoignez la communauté Roblox de roleplay SCP francophone. Incarnez un agent de la Fondation SCP dans le Site-21, un jeu immersif et sérieux en français. Bêta publique en août 2026."
    keywords="Site 21 RP, SCP Roblox, roleplay SCP, Fondation SCP, jeu Roblox français, SCP RP communauté, RP immersif Roblox, SCP Foundation game"
>
    <!-- ── HERO ── -->
    <section class="hs-hero" aria-labelledby="hero-title">
        <div class="hero-bg-glow" aria-hidden="true"></div>
        <div class="hero-light-pillar" aria-hidden="true">
            <LightPillar
                client:only="react"
                topColor="#cc0000"
                bottomColor="#330000"
                intensity={1.1}
                rotationSpeed={0.4}
                glowAmount={0.009}
                pillarWidth={5.5}
                pillarHeight={0.35}
                noiseIntensity={0.5}
                pillarRotation={38}
                interactive={false}
                mixBlendMode="normal"
                quality="medium"
            />
        </div>
        <canvas id="particle-canvas" aria-hidden="true"></canvas>

        <div class="hs-hero-content">
            <img
                src="/logos/site21_logo.webp"
                alt=""
                aria-hidden="true"
                class="hero-logo-img"
            />
            <p class="hs-hero-subtitle">Sécuriser. Contenir. Protéger</p>
            <h1
                id="hero-title"
                class="hs-hero-title"
                data-glitch="SCP RP SITE-21"
            >
                SCP RP SITE-21
            </h1>
            <p class="hs-hero-tagline">Le roleplay SCP français sur Roblox</p>

            <div class="hs-hero-actions">
                <a
                    href={DISCORD}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-discord"
                >
                    ◈ Rejoindre Discord
                </a>
                <a href="/jeu" class="btn btn-hs-primary">
                    ▶ Découvrir le jeu
                </a>
            </div>
        </div>

        <div class="hero-scroll-hint" aria-hidden="true">DÉFILER</div>
    </section>

    <!-- ── STATS BAR ── -->
    <section class="hs-stats-bar" aria-label="Statistiques">
        <div class="hs-stats-bar-inner">
            <div class="stat-block scroll-reveal" data-stagger="0">
                <span class="stat-number" data-count-to="80">80</span>
                <span class="stat-label">Membres</span>
            </div>
            <div class="stat-block scroll-reveal" data-stagger="1">
                <span class="stat-number" data-count-to="6">6</span>
                <span class="stat-label">Départements jouables</span>
            </div>
            <div class="stat-block scroll-reveal" data-stagger="2">
                <span class="stat-number" data-count-to="2021">2021</span>
                <span class="stat-label">Fondé en</span>
            </div>
            <div class="stat-block scroll-reveal" data-stagger="3">
                <span class="stat-number" data-count-to="2026">2026</span>
                <span class="stat-label">Août — Sortie</span>
            </div>
        </div>
    </section>

    <!-- ── LE JEU — texte gauche / image droite ── -->
    <section class="mod-section mod-section--alt">
        <div class="container">
            <div class="mod-split mod-reveal">
                <div class="mod-split-text">
                    <div class="mod-eyebrow mod-eyebrow--left">// Le Jeu</div>
                    <h2 class="mod-title">Un roleplay SCP <em>immersif</em></h2>
                    <p class="mod-split-desc">
                        Enfoui sous les glaces de l'Alaska, le Site-21 abrite
                        certaines des pires anomalies jamais recensées. Incarnez
                        un agent de sécurité, un scientifique ou un Classe-D
                        dans un complexe de confinement persistant — où rien
                        n'est jamais vraiment sous contrôle.
                    </p>
                    <ul class="mod-split-list">
                        <li>
                            6 départements jouables, chacun avec sa hiérarchie
                            et ses zones d'accès
                        </li>
                        <li>
                            Brèches de confinement, protocoles et événements
                            scénarisés
                        </li>
                        <li>
                            Progression par niveaux d'accréditation — du Niveau
                            1 au Conseil O5
                        </li>
                        <li>
                            Free-RP : écrivez votre propre histoire, à votre
                            rythme
                        </li>
                    </ul>
                    <div class="mod-split-actions">
                        <a href="/jeu" class="mod-cta">Découvrir le jeu</a>
                        <a
                            href={ROBLOX_J}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="mod-cta mod-cta--ghost"
                        >
                            ▶ Jouer — Août 2026
                        </a>
                    </div>
                </div>
                <div class="mod-split-media">
                    <img
                        src="/screenshots/spoil_sias.webp"
                        alt="Vue intérieure du Site-21 — passerelle du département scientifique"
                        class="mod-split-img"
                        loading="lazy"
                    />
                    <span class="mod-split-caption"
                        >// Capture — développement en cours</span
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- ── LA COMMUNAUTÉ — image gauche / texte droite ── -->
    <section class="mod-section">
        <div class="container">
            <div class="mod-split mod-split--flip mod-reveal">
                <div class="mod-split-text">
                    <div class="mod-eyebrow mod-eyebrow--left">
                        // La Communauté
                    </div>
                    <h2 class="mod-title">
                        Une communauté <em>passionnée</em>
                    </h2>
                    <p class="mod-split-desc">
                        Née en 2021 de la rencontre de deux passionnés, la
                        communauté Site-21 est aujourd'hui 100% française et
                        entièrement dédiée au roleplay SCP de qualité. Le RP ne
                        fonctionne que grâce à la communauté — et vous en faites
                        partie.
                    </p>
                    <ul class="mod-split-list">
                        <li>Plus de 80 membres actifs sur Discord</li>
                        <li>Événements RP et communautaires réguliers</li>
                        <li>Une équipe de modération dédiée et à l'écoute</li>
                        <li>
                            Des serveurs affiliés qui enrichissent l'univers
                        </li>
                    </ul>
                    <div class="mod-split-actions">
                        <a
                            href={DISCORD}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="mod-cta"
                        >
                            ◈ Rejoindre le Discord
                        </a>
                        <a href="/communaute" class="mod-cta mod-cta--ghost"
                            >Voir la communauté</a
                        >
                    </div>
                </div>
                <div class="mod-split-media">
                    <img
                        src="/screenshots/spoil_cutscene_contract.webp"
                        alt="L'équipe du Site-21 réunie en jeu"
                        class="mod-split-img"
                        loading="lazy"
                    />
                    <span class="mod-split-caption"
                        >// L'équipe du Site-21 — capture in-game</span
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- ── COMPTE À REBOURS — 21 AOÛT ── -->
    <section class="mod-section mod-countdown-section">
        <div class="container">
            <div class="mod-heading mod-heading--center mod-reveal">
                <div class="mod-eyebrow">21 AOÛT 2026</div>
                <h2 class="mod-title">Quelque chose <em>se prépare</em></h2>
                <p class="mod-subtitle">
                    Le contenu de cette annonce est <span class="redacted"
