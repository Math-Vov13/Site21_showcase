                    >. Rendez-vous le 21 août.
                </p>
            </div>

            <div
                class="mod-countdown mod-reveal"
                data-mod-delay="1"
                data-countdown-target="2026-08-21T00:00:00+02:00"
            >
                <div class="mod-count-block">
                    <span class="mod-count-num" data-cd="days">--</span>
                    <span class="mod-count-label">Jours</span>
                </div>
                <div class="mod-count-block">
                    <span class="mod-count-num" data-cd="hours">--</span>
                    <span class="mod-count-label">Heures</span>
                </div>
                <div class="mod-count-block">
                    <span class="mod-count-num" data-cd="minutes">--</span>
                    <span class="mod-count-label">Minutes</span>
                </div>
                <div class="mod-count-block">
                    <span class="mod-count-num" data-cd="seconds">--</span>
                    <span class="mod-count-label">Secondes</span>
                </div>
            </div>

            <div class="mod-countdown-actions mod-reveal" data-mod-delay="2">
                <a
                    href={DISCORD}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mod-cta"
                >
                    ◈ Être prévenu sur Discord
                </a>
            </div>
        </div>
    </section>

    <!-- ── ACTUALITÉS ── -->
    <section class="mod-section">
        <div class="container container--narrow">
            <div class="mod-heading mod-reveal">
                <div class="mod-eyebrow mod-eyebrow--left">JOURNAL DE BORD</div>
                <h2 class="mod-title">Actualités</h2>
                <p class="mod-subtitle">
                    Suivez le déploiement du Site-21 — mises à jour, annonces et
