                            <p>
                                Oui — des événements RP et communautaires sont
                                organisés régulièrement par l'équipe. Le
                                calendrier et les annonces sont relayés sur le
                                Discord.
                            </p>
                            <a href="/communaute" class="mod-faq-link"
                                >Voir la communauté</a
                            >
                        </div>
                    </details>

                    <details class="mod-faq-item">
                        <summary class="mod-faq-q"
                            >Qui est derrière le projet&nbsp;?</summary
                        >
                        <div class="mod-faq-a">
                            <p>
                                Une équipe de bénévoles passionnés — fondateurs,
                                développeurs, staff et anciens. Retrouvez-les
                                tous sur la page crédits.
                            </p>
                            <a href="/credits" class="mod-faq-link"
                                >Voir l'équipe</a
                            >
                        </div>
                    </details>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    /* ── Particle System ── */
    (function () {
        const canvas = document.getElementById(
            "particle-canvas",
        ) as HTMLCanvasElement | null;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;
        const cvs = canvas as HTMLCanvasElement;
        const gfx = ctx as CanvasRenderingContext2D;

        const colors = ["#cc0000", "#ff0000", "#660000", "#cc2200", "#880000"];
        let particles: any[] = [];
        const mouse = { x: -9999, y: -9999 };

        function resize() {
            cvs.width = cvs.offsetWidth;
            cvs.height = cvs.offsetHeight;
        }

        function makeParticle(y?: number) {
            return {
                x: Math.random() * (cvs.width || 800),
                y: y !== undefined ? y : Math.random() * (cvs.height || 600),
                vx: (Math.random() - 0.5) * 0.25,
                vy: -(Math.random() * 0.25 + 0.05),
                size: 0.5 + Math.random() * 1.7,
                opacity: 0,
                targetOpacity: Math.random() * 0.35 + 0.05,
                life: Math.random() * 1000,
                color: colors[Math.floor(Math.random() * colors.length)],
            };
        }

        resize();
        particles = Array.from(
            { length: window.innerWidth < 768 ? 40 : 80 },
            () => makeParticle(),
        );

        window.addEventListener("resize", resize);
        window.addEventListener("mousemove", (e) => {
            const r = cvs.getBoundingClientRect();
            mouse.x = e.clientX - r.left;
            mouse.y = e.clientY - r.top;
        });

        function loop() {
            gfx.clearRect(0, 0, cvs.width, cvs.height);
            particles.forEach((p, i) => {
                p.life += 0.5;
                p.vx += Math.sin(p.life * 0.008 + i * 0.3) * 0.006;
                p.x += p.vx;
                p.y += p.vy;
                const dx = p.x - mouse.x,
                    dy = p.y - mouse.y;
                const d = Math.sqrt(dx * dx + dy * dy);
                if (d < 90 && d > 1) {
                    const f = ((90 - d) / 90) * 0.4;
                    p.vx += (dx / d) * f;
                    p.vy += (dy / d) * f;
                }
                p.vx *= 0.98;
                p.vy = Math.max(p.vy, -0.5);
                p.opacity += (p.targetOpacity - p.opacity) * 0.025;
                if (Math.abs(p.opacity - p.targetOpacity) < 0.01)
                    p.targetOpacity = Math.random() * 0.35 + 0.05;
                if (p.y < -10) Object.assign(p, makeParticle(cvs.height + 5));
                if (p.x < -10) p.x = cvs.width + 5;
                if (p.x > cvs.width + 10) p.x = -5;
            });
            for (let i = 0; i < particles.length; i++)
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const d = Math.sqrt(dx * dx + dy * dy);
                    if (d < 110) {
                        gfx.strokeStyle = `rgba(204,0,0,${(1 - d / 110) * 0.12})`;
                        gfx.lineWidth = 0.5;
                        gfx.beginPath();
                        gfx.moveTo(particles[i].x, particles[i].y);
                        gfx.lineTo(particles[j].x, particles[j].y);
                        gfx.stroke();
                    }
                }
            particles.forEach((p) => {
                gfx.beginPath();
                gfx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                gfx.fillStyle = p.color;
                gfx.globalAlpha = p.opacity;
                gfx.fill();
            });
            gfx.globalAlpha = 1;
            requestAnimationFrame(loop);
        }
        loop();
    })();

    /* ── Compte à rebours 21 août ── */
    (function () {
        const root = document.querySelector<HTMLElement>(
            "[data-countdown-target]",
        );
        if (!root) return;
        const target = new Date(root.dataset.countdownTarget || "").getTime();
        if (Number.isNaN(target)) return;

        const fields = ["days", "hours", "minutes", "seconds"] as const;
        const els = new Map(
            fields.map((f) => [
                f,
                root.querySelector<HTMLElement>(`[data-cd="${f}"]`),
            ]),
        );
        const pad = (n: number) => String(n).padStart(2, "0");

        function tick() {
            const diff = Math.max(0, target - Date.now());
            const days = Math.floor(diff / 86400000);
            const hours = Math.floor((diff % 86400000) / 3600000);
            const minutes = Math.floor((diff % 3600000) / 60000);
            const seconds = Math.floor((diff % 60000) / 1000);
            const values = { days, hours, minutes, seconds };
            fields.forEach((f) => {
                const el = els.get(f);
                if (el)
                    el.textContent =
                        f === "days" ? String(values[f]) : pad(values[f]);
            });
        }

        tick();
        setInterval(tick, 1000);
    })();

    /* ── Modern scroll reveal ── */
    (function () {
        const els = document.querySelectorAll<HTMLElement>(".mod-reveal");
        if (!els.length) return;
        const obs = new IntersectionObserver(
            (entries) => {
                entries.forEach((e) => {
                    if (e.isIntersecting) {
                        e.target.classList.add("is-visible");
                        obs.unobserve(e.target);
                    }
                });
            },
            { threshold: 0.1 },
        );
        els.forEach((el) => obs.observe(el));
    })();
</script>
